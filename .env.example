# football-data.org — required for live data (free key)
# Sign up: https://www.football-data.org/client/register
# Without this the app serves mock fixtures.
FOOTBALL_DATA_API_KEY=

# API-Football — optional enrichment for Barca matches (free 100 req/day)
# Sign up: https://dashboard.api-football.com/register
API_FOOTBALL_KEY=

# Bearer token required for POST /api/news (any random string)
ADMIN_TOKEN=

# Telegram channel link surfaced in the CTA
NEXT_PUBLIC_TELEGRAM_URL=https://t.me/your_channel

# Cache TTLs (seconds)
SCORES_TTL_SECONDS=30
LIST_TTL_SECONDS=60
NEWS_TTL_SECONDS=600

# Google AdSense — leave empty until your account is approved.
# Slot ids are AdSense-side identifiers per ad unit.
NEXT_PUBLIC_ADSENSE_CLIENT=
NEXT_PUBLIC_ADSENSE_SLOT_300x250=
NEXT_PUBLIC_ADSENSE_SLOT_320x100=
NEXT_PUBLIC_ADSENSE_SLOT_320x50=

# Public site URL (used for sitemap, robots.txt, OG metadata)
SITE_URL=https://example.com

# Upstash Redis (for blog post storage). Auto-injected by the Vercel
# Marketplace integration; locally the app falls back to in-memory.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
