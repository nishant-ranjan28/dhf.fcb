# Football data provider — defaults to "mock" if unset.
# Set to "api-football" once you implement fetchApiFootballAll() in lib/football.ts
FOOTBALL_PROVIDER=mock
FOOTBALL_API_KEY=

# Cache TTLs (seconds)
SCORES_TTL_SECONDS=30
LIST_TTL_SECONDS=60

# Telegram channel link surfaced in the CTA
NEXT_PUBLIC_TELEGRAM_URL=https://t.me/your_channel
